# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
HOST=0.0.0.0
PORT=5000

# Upload Configuration
UPLOAD_FOLDER=/tmp/uploads
MAX_CONTENT_LENGTH=50MB

# FAISS Index Path
FAISS_INDEX_PATH=backend/data/faiss_index.index

# Processed Data Path
PROCESSED_DATA_PATH=backend/data

# Hugging Face Model Cache (optional - set to reduce cold start)
TRANSFORMERS_CACHE=/tmp/transformers_cache
HF_DATASETS_CACHE=/tmp/datasets_cache